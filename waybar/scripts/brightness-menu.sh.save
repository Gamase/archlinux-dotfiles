#!/bin/bash
CURRENT=$(brightnessctl get)
MAX=$(brightnessctl max)
PERC=$((CURRENT * 100 / MAX))

yad --scale \
    --title="Brillo" \
    --text="󰃠  Brillo" \
    --value=$PERC \
    --min-value=1 \
    --max-value=100 \
    --step=1 \
    --print-partial \
    --no-buttons \
    --fixed \
    --width=300 \
    --height=80 \
    --borders=15 \
    --css="
        window {
            background-color: rgba(12,0,0,0.95);
            border: 1px solid #3a0000;
            border-radius: 10px;
        }
        scale trough {
            background-color: #3a0000;
            border-radius: 5px;
        }
        scale highlight {
            background-color: #ff0033;
            border-radius: 5px;
        }
        scale slider {
            background-color: #ff0033;
            border-radius: 50%;
            min-width: 16px;
            min-height: 16px;
        }
        label {
            color: #ff3333;
            font-family: JetBrainsMono Nerd Font;
            font-size: 13px;
        }
    " | while read -r val; do
        brightnessctl set "$val%"
    done
